<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Developer Platform | Flinker APIs &amp; SDKs on Flinker | The built-environment layer for Microsoft 365</title><link>https://flinker.app/developers/</link><description>Recent content in Developer Platform | Flinker APIs &amp; SDKs on Flinker | The built-environment layer for Microsoft 365</description><generator>Hugo</generator><language>en-us</language><lastBuildDate>Mon, 16 Feb 2026 00:00:00 +0000</lastBuildDate><atom:link href="https://flinker.app/developers/index.xml" rel="self" type="application/rss+xml"/><item><title>IFC Copilot API | AI-Powered BIM Data Extraction | Flinker</title><link>https://flinker.app/developers/ifc-copilot/</link><pubDate>Sat, 14 Feb 2026 00:00:00 +0000</pubDate><guid>https://flinker.app/developers/ifc-copilot/</guid><description>&lt;!-- Hero Section -->
&lt;section class="py-md-10 pt-5 bg-primary bg-opacity-10 position-relative">
 &lt;div class="position-absolute top-0 start-0 end-0" style="height: 80px; background: linear-gradient(to bottom, rgba(0,0,0,0.35), transparent); pointer-events: none; z-index: 0;">&lt;/div>
 &lt;div class="container">
 &lt;div class="row align-items-center py-lg-8">
 &lt;div class="col-lg-6 col-12">
 &lt;div class="text-center text-lg-start">
 &lt;span class="badge bg-primary mb-3">API&lt;/span>
 &lt;h1 class="display-5">IFC Copilot API&lt;/h1>
 &lt;p class="lead">AI-powered IFC data extraction. Query building models using natural language and get structured, actionable data back.&lt;/p>
 &lt;div class="mt-5">
 &lt;a href="https://docs.flinker.app/" class="btn btn-primary me-2" target="_blank">Documentation&lt;/a>
 &lt;a href="https://copilot.flinker.app/" class="btn btn-outline-dark" target="_blank">Try Copilot&lt;/a>
 &lt;/div>
 &lt;/div>
 &lt;/div>
 &lt;div class="col-lg-6 col-12">
 &lt;div class="text-center">
 &lt;svg width="380" height="300" viewBox="0 0 380 300" fill="none" xmlns="http://www.w3.org/2000/svg">
 &lt;defs>
 &lt;!-- Flinker brand gradients -->
 &lt;linearGradient id="flinkerPrimary" x1="0%" y1="0%" x2="100%" y2="100%">
 &lt;stop offset="0%" style="stop-color:#0779FF;stop-opacity:1" />
 &lt;stop offset="100%" style="stop-color:#0560cc;stop-opacity:1" />
 &lt;/linearGradient>
 &lt;linearGradient id="flinkerLight" x1="0%" y1="0%" x2="100%" y2="100%">
 &lt;stop offset="0%" style="stop-color:#96BFFF;stop-opacity:0.7" />
 &lt;stop offset="100%" style="stop-color:#0779FF;stop-opacity:0.4" />
 &lt;/linearGradient>
 &lt;linearGradient id="flinkerGlow" x1="0%" y1="0%" x2="100%" y2="100%">
 &lt;stop offset="0%" style="stop-color:#0779FF;stop-opacity:0.15" />
 &lt;stop offset="100%" style="stop-color:#96BFFF;stop-opacity:0.05" />
 &lt;/linearGradient>
 &lt;linearGradient id="aiGradient" x1="0%" y1="0%" x2="100%" y2="100%">
 &lt;stop offset="0%" style="stop-color:#0779FF;stop-opacity:1" />
 &lt;stop offset="50%" style="stop-color:#96BFFF;stop-opacity:0.8" />
 &lt;stop offset="100%" style="stop-color:#0560cc;stop-opacity:1" />
 &lt;/linearGradient>
 &lt;linearGradient id="codeGradient" x1="0%" y1="0%" x2="0%" y2="100%">
 &lt;stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
 &lt;stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
 &lt;/linearGradient>
 &lt;filter id="softGlow" x="-50%" y="-50%" width="200%" height="200%">
 &lt;feGaussianBlur stdDeviation="3" result="coloredBlur"/>
 &lt;feMerge>
 &lt;feMergeNode in="coloredBlur"/>
 &lt;feMergeNode in="SourceGraphic"/>
 &lt;/feMerge>
 &lt;/filter>
 &lt;filter id="dropShadow" x="-20%" y="-20%" width="140%" height="140%">
 &lt;feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#0779FF" flood-opacity="0.25"/>
 &lt;/filter>
 &lt;/defs>

 &lt;!-- Background glow -->
 &lt;ellipse cx="190" cy="150" rx="150" ry="120" fill="url(#flinkerGlow)" />

 &lt;!-- Chat bubble / Natural Language Input (left) -->
 &lt;g transform="translate(25, 45)" filter="url(#dropShadow)">
 &lt;rect x="0" y="0" width="120" height="75" rx="12" fill="white" stroke="#e2e8f0" stroke-width="1.5"/>
 &lt;polygon points="25,75 35,90 45,75" fill="white" stroke="#e2e8f0" stroke-width="1.5" stroke-linejoin="round"/>
 &lt;line x1="25" y1="75" x2="45" y2="75" stroke="white" stroke-width="2"/>
 &lt;!-- Text lines representing user query -->
 &lt;rect x="15" y="18" width="70" height="6" rx="3" fill="#0779FF" opacity="0.8"/>
 &lt;rect x="15" y="30" width="90" height="6" rx="3" fill="#96BFFF" opacity="0.6"/>
 &lt;rect x="15" y="42" width="55" height="6" rx="3" fill="#96BFFF" opacity="0.4"/>
 &lt;!-- Question mark icon -->
 &lt;circle cx="100" cy="55" r="12" fill="url(#flinkerPrimary)" opacity="0.15"/>
 &lt;text x="100" y="60" fill="#0779FF" font-size="14" text-anchor="middle" font-weight="bold" font-family="system-ui">?&lt;/text>
 &lt;/g>

 &lt;!-- Central AI Processing Element -->
 &lt;g transform="translate(155, 85)">
 &lt;!-- Outer ring - rotating effect -->
 &lt;circle cx="45" cy="55" r="52" stroke="url(#flinkerLight)" stroke-width="2" fill="none" stroke-dasharray="8,6" opacity="0.6">
 &lt;animateTransform attributeName="transform" type="rotate" from="0 45 55" to="360 45 55" dur="20s" repeatCount="indefinite"/>
 &lt;/circle>
 &lt;!-- Inner glow circle -->
 &lt;circle cx="45" cy="55" r="42" fill="url(#flinkerGlow)" />
 &lt;!-- AI brain/neural icon -->
 &lt;circle cx="45" cy="55" r="35" fill="white" stroke="url(#flinkerPrimary)" stroke-width="2.5" filter="url(#dropShadow)"/>
 &lt;!-- Neural network nodes -->
 &lt;g filter="url(#softGlow)">
 &lt;!-- Center node -->
 &lt;circle cx="45" cy="55" r="6" fill="url(#flinkerPrimary)"/>
 &lt;!-- Surrounding nodes -->
 &lt;circle cx="30" cy="42" r="4" fill="#0779FF"/>
 &lt;circle cx="60" cy="42" r="4" fill="#0779FF"/>
 &lt;circle cx="28" cy="62" r="4" fill="#0779FF"/>
 &lt;circle cx="62" cy="62" r="4" fill="#0779FF"/>
 &lt;circle cx="45" cy="75" r="4" fill="#0779FF"/>
 &lt;circle cx="45" cy="35" r="4" fill="#0779FF"/>
 &lt;!-- Connection lines -->
 &lt;line x1="45" y1="55" x2="30" y2="42" stroke="#96BFFF" stroke-width="1.5"/>
 &lt;line x1="45" y1="55" x2="60" y2="42" stroke="#96BFFF" stroke-width="1.5"/>
 &lt;line x1="45" y1="55" x2="28" y2="62" stroke="#96BFFF" stroke-width="1.5"/>
 &lt;line x1="45" y1="55" x2="62" y2="62" stroke="#96BFFF" stroke-width="1.5"/>
 &lt;line x1="45" y1="55" x2="45" y2="75" stroke="#96BFFF" stroke-width="1.5"/>
 &lt;line x1="45" y1="55" x2="45" y2="35" stroke="#96BFFF" stroke-width="1.5"/>
 &lt;!-- Cross connections -->
 &lt;line x1="30" y1="42" x2="60" y2="42" stroke="#96BFFF" stroke-width="1" opacity="0.5"/>
 &lt;line x1="28" y1="62" x2="62" y2="62" stroke="#96BFFF" stroke-width="1" opacity="0.5"/>
 &lt;/g>
 &lt;!-- Pulsing effect -->
 &lt;circle cx="45" cy="55" r="35" fill="none" stroke="#0779FF" stroke-width="1" opacity="0.5">
 &lt;animate attributeName="r" values="35;45;35" dur="2s" repeatCount="indefinite"/>
 &lt;animate attributeName="opacity" values="0.5;0;0.5" dur="2s" repeatCount="indefinite"/>
 &lt;/circle>
 &lt;/g>

 &lt;!-- 3D IFC Building (behind/integrated with AI) -->
 &lt;g transform="translate(170, 175)">
 &lt;!-- Simple 3D building -->
 &lt;path d="M30 15 L55 5 L55 55 L30 65 Z" fill="#0560cc" opacity="0.6"/>
 &lt;path d="M5 25 L30 15 L30 65 L5 75 Z" fill="url(#flinkerPrimary)" opacity="0.7"/>
 &lt;path d="M5 25 L30 15 L55 5 L30 15 Z" fill="#96BFFF" opacity="0.5"/>
 &lt;!-- Windows -->
 &lt;rect x="10" y="35" width="8" height="10" rx="1" fill="#96BFFF" opacity="0.6"/>
 &lt;rect x="10" y="50" width="8" height="10" rx="1" fill="#96BFFF" opacity="0.6"/>
 &lt;rect x="22" y="35" width="6" height="8" rx="1" fill="#96BFFF" opacity="0.4"/>
 &lt;/g>

 &lt;!-- JSON/Code Output (right) -->
 &lt;g transform="translate(250, 160)" filter="url(#dropShadow)">
 &lt;rect x="0" y="0" width="105" height="100" rx="8" fill="url(#codeGradient)"/>
 &lt;!-- Code header bar -->
 &lt;rect x="0" y="0" width="105" height="22" rx="8" fill="#334155"/>
 &lt;rect x="0" y="14" width="105" height="8" fill="#334155"/>
 &lt;!-- Dots -->
 &lt;circle cx="14" cy="11" r="4" fill="#ef4444"/>
 &lt;circle cx="28" cy="11" r="4" fill="#fbbf24"/>
 &lt;circle cx="42" cy="11" r="4" fill="#22c55e"/>
 &lt;!-- JSON content -->
 &lt;text x="10" y="40" fill="#94a3b8" font-size="10" font-family="monospace">{&lt;/text>
 &lt;text x="16" y="54" fill="#0779FF" font-size="10" font-family="monospace">"walls"&lt;/text>
 &lt;text x="60" y="54" fill="#94a3b8" font-size="10" font-family="monospace">:&lt;/text>
 &lt;text x="68" y="54" fill="#22c55e" font-size="10" font-family="monospace">247&lt;/text>
 &lt;text x="16" y="70" fill="#0779FF" font-size="10" font-family="monospace">"doors"&lt;/text>
 &lt;text x="62" y="70" fill="#94a3b8" font-size="10" font-family="monospace">:&lt;/text>
 &lt;text x="70" y="70" fill="#22c55e" font-size="10" font-family="monospace">58&lt;/text>
 &lt;text x="16" y="86" fill="#0779FF" font-size="10" font-family="monospace">"area"&lt;/text>
 &lt;text x="54" y="86" fill="#94a3b8" font-size="10" font-family="monospace">:&lt;/text>
 &lt;text x="62" y="86" fill="#22c55e" font-size="10" font-family="monospace">1250&lt;/text>
 &lt;text x="10" y="96" fill="#94a3b8" font-size="10" font-family="monospace">}&lt;/text>
 &lt;/g>

 &lt;!-- Flow arrows -->
 &lt;g filter="url(#softGlow)">
 &lt;!-- Arrow from chat to AI -->
 &lt;path d="M145 95 Q160 95 162 110" stroke="#0779FF" stroke-width="2" fill="none" stroke-dasharray="5,3">
 &lt;animate attributeName="stroke-dashoffset" values="16;0" dur="1s" repeatCount="indefinite"/>
 &lt;/path>
 &lt;polygon points="162,118 157,108 167,108" fill="#0779FF"/>

 &lt;!-- Arrow from AI to JSON output -->
 &lt;path d="M238 150 Q250 155 252 168" stroke="#0779FF" stroke-width="2" fill="none" stroke-dasharray="5,3">
 &lt;animate attributeName="stroke-dashoffset" values="16;0" dur="1s" repeatCount="indefinite"/>
 &lt;/path>
 &lt;polygon points="255,175 248,167 258,165" fill="#0779FF"/>
 &lt;/g>

 &lt;!-- Labels -->
 &lt;g>
 &lt;text x="85" y="155" fill="#64748b" font-size="11" text-anchor="middle" font-family="system-ui" font-weight="500">Natural Language&lt;/text>
 &lt;text x="200" y="50" fill="#64748b" font-size="11" text-anchor="middle" font-family="system-ui" font-weight="500">AI Analysis&lt;/text>
 &lt;text x="302" y="275" fill="#64748b" font-size="11" text-anchor="middle" font-family="system-ui" font-weight="500">Structured Data&lt;/text>
 &lt;/g>

 &lt;!-- Floating data particles -->
 &lt;g opacity="0.6">
 &lt;circle cx="120" cy="180" r="2" fill="#0779FF">
 &lt;animate attributeName="cy" values="180;160;180" dur="3s" repeatCount="indefinite"/>
 &lt;animate attributeName="opacity" values="0.6;0.2;0.6" dur="3s" repeatCount="indefinite"/>
 &lt;/circle>
 &lt;circle cx="260" cy="135" r="2" fill="#96BFFF">
 &lt;animate attributeName="cy" values="135;120;135" dur="2.5s" repeatCount="indefinite"/>
 &lt;animate attributeName="opacity" values="0.6;0.2;0.6" dur="2.5s" repeatCount="indefinite"/>
 &lt;/circle>
 &lt;circle cx="320" cy="145" r="2" fill="#0779FF">
 &lt;animate attributeName="cy" values="145;130;145" dur="2s" repeatCount="indefinite"/>
 &lt;animate attributeName="opacity" values="0.6;0.2;0.6" dur="2s" repeatCount="indefinite"/>
 &lt;/circle>
 &lt;/g>
 &lt;/svg>
 &lt;/div>
 &lt;/div>
 &lt;/div>
 &lt;/div>
&lt;/section>

&lt;!-- Capabilities -->
&lt;section class="py-9">
 &lt;div class="container">
 &lt;div class="row mb-8">
 &lt;div class="col-lg-8 offset-lg-2 text-center">
 &lt;h2 class="mb-3">What You Can Do&lt;/h2>
 &lt;/div>
 &lt;/div>
 &lt;div class="row g-4">
 &lt;div class="col-md-6">
 &lt;div class="card h-100 border-0 shadow-sm">
 &lt;div class="card-body p-4">
 &lt;i class="bi bi-calculator fs-3 text-primary mb-3">&lt;/i>
 &lt;h5>Quantity Takeoffs&lt;/h5>
 &lt;p class="text-muted mb-0">Extract quantities, areas, volumes, and counts from IFC models using natural language queries like "How many doors are on level 2?"&lt;/p></description></item></channel></rss>