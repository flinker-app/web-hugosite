 /* Calculator scoped styles */
 .calc-card {
 border: 1px solid #e2e8f0;
 border-radius: 16px;
 padding: 40px;
 background: #fff;
 box-shadow: 0 10px 30px rgba(15,23,42,.06);
 position: relative;
 overflow: hidden;
 }
 .calc-card::before {
 content: '';
 position: absolute;
 top: 0; left: 0; right: 0;
 height: 3px;
 background: linear-gradient(90deg, var(--bs-primary), #10b981);
 border-radius: 16px 16px 0 0;
 }
 .calc-label {
 font-size: 12px;
 font-weight: 700;
 color: #64748b;
 letter-spacing: 0.08em;
 text-transform: uppercase;
 margin-bottom: 28px;
 }
 .calc-slider-wrap {
 margin-bottom: 32px;
 }
 .calc-slider-header {
 display: flex;
 justify-content: space-between;
 align-items: baseline;
 margin-bottom: 12px;
 }
 .calc-slider-title { font-size: 14px; color: #64748b; }
 .calc-slider-value {
 font-size: 28px;
 font-weight: 700;
 color: var(--bs-emphasis-color, #0f172a);
 transition: color 0.2s;
 }

 .calc-range {
 -webkit-appearance: none;
 width: 100%;
 height: 6px;
 background: #e2e8f0;
 outline: none;
 border-radius: 3px;
 cursor: pointer;
 }
 .calc-range::-webkit-slider-thumb {
 -webkit-appearance: none;
 width: 22px;
 height: 22px;
 background: var(--bs-primary, #007bff);
 border-radius: 50%;
 cursor: pointer;
 transition: transform 0.15s;
 box-shadow: 0 2px 8px rgba(0,123,255,0.3);
 }
 .calc-range::-webkit-slider-thumb:hover { transform: scale(1.15); }
 .calc-range::-moz-range-thumb {
 width: 22px;
 height: 22px;
 background: var(--bs-primary, #007bff);
 border-radius: 50%;
 cursor: pointer;
 border: none;
 box-shadow: 0 2px 8px rgba(0,123,255,0.3);
 }

 .calc-tick-labels {
 display: flex;
 justify-content: space-between;
 margin-top: 8px;
 }
 .calc-tick-labels span {
 font-size: 11px;
 font-weight: 500;
 color: #94a3b8;
 }

 /* Tier recommendation box */
 .tier-rec {
 border: 1px solid #e2e8f0;
 border-radius: 16px;
 padding: 24px 28px;
 background: #f8fafc;
 display: flex;
 align-items: center;
 justify-content: space-between;
 gap: 16px;
 transition: all 0.3s ease;
 }
 .tier-rec.rec-starter {
 background: rgba(16,185,129,0.06);
 border-color: rgba(16,185,129,0.25);
 }
 .tier-rec.rec-enterprise {
 background: rgba(14,165,233,0.06);
 border-color: rgba(14,165,233,0.25);
 }
 .rec-label {
 font-size: 12px;
 font-weight: 700;
 color: #64748b;
 letter-spacing: 0.06em;
 text-transform: uppercase;
 margin-bottom: 4px;
 }
 .rec-tier {
 font-size: 24px;
 font-weight: 700;
 color: var(--bs-emphasis-color, #0f172a);
 transition: color 0.3s;
 }
 .tier-rec.rec-starter .rec-tier { color: #10b981; }
 .tier-rec.rec-enterprise .rec-tier { color: #0ea5e9; }
 .rec-desc {
 font-size: 13px;
 color: #64748b;
 line-height: 1.5;
 margin-top: 2px;
 }
 .rec-amount {
 font-size: 44px;
 font-weight: 700;
 line-height: 1;
 color: var(--bs-primary, #007bff);
 transition: all 0.3s ease;
 }
 .tier-rec.rec-starter .rec-amount { color: #10b981; }
 .tier-rec.rec-enterprise .rec-amount { color: #0ea5e9; }
 .rec-period {
 font-size: 13px;
 font-weight: 500;
 color: #94a3b8;
 margin-top: 4px;
 text-align: right;
 }

 /* Plan cards */
 .plan {
 border: 1px solid #e2e8f0;
 border-radius: 16px;
 padding: 26px;
 background: #fff;
 box-shadow: 0 10px 30px rgba(15,23,42,.06);
 transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
 position: relative;
 }
 .plan:hover {
 transform: translateY(-3px);
 box-shadow: 0 14px 36px rgba(15,23,42,.1);
 }
 .plan-accent {
 border: 2px solid var(--bs-primary, #007bff);
 box-shadow: 0 10px 30px rgba(0,123,255,.12);
 }
 .plan-badge {
 position: absolute;
 top: -1px; right: 20px;
 background: var(--bs-primary, #007bff);
 color: #fff;
 font-size: 11px;
 font-weight: 700;
 padding: 4px 12px;
 letter-spacing: 0.04em;
 text-transform: uppercase;
 border-radius: 0 0 8px 8px;
 }
 .plan-name {
 font-size: 12px;
 font-weight: 700;
 color: #64748b;
 letter-spacing: 0.08em;
 text-transform: uppercase;
 margin-bottom: 14px;
 }
 .plan-opens {
 font-size: 13px;
 color: #64748b;
 margin-bottom: 12px;
 line-height: 1.4;
 }
 .plan-price {
 font-size: 24px;
 font-weight: 700;
 color: var(--bs-primary, #007bff);
 margin-bottom: 4px;
 }
 .plan-per {
 font-size: 13px;
 color: #64748b;
 margin-bottom: 18px;
 }

 /* Info rows */
 .info-row {
 border: 1px solid #e2e8f0;
 border-radius: 16px;
 padding: 22px 28px;
 background: #fff;
 display: flex;
 justify-content: space-between;
 align-items: center;
 box-shadow: 0 4px 12px rgba(15,23,42,.04);
 }
 .info-row-price {
 font-size: 26px;
 font-weight: 700;
 color: var(--bs-primary, #007bff);
 white-space: nowrap;
 }

 /* Pilot note */
 .pilot-note {
 border: 1px solid rgba(16,185,129,0.25);
 background: rgba(16,185,129,0.04);
 border-radius: 16px;
 padding: 20px 28px;
 display: flex;
 align-items: flex-start;
 gap: 16px;
 }
 .pilot-note strong { color: #10b981; font-weight: 600; }

 @media (max-width: 768px) {
 .calc-card { padding: 24px 18px; }
 .tier-rec { flex-direction: column; align-items: flex-start; }
 .rec-amount { font-size: 36px; }
 .rec-period { text-align: left; }
 .info-row { flex-direction: column; gap: 14px; align-items: flex-start; }
 }
&lt;/style>

